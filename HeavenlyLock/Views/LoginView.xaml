<UserControl x:Class="HeavenlyLock.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- OVERLAY: Recovery Phrase Display (after vault create OR password reset) -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{StaticResource BackgroundBrush}"
                Visibility="{Binding ShowRecoveryPhrase, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="16"
                        Padding="40,30"
                        Width="520"
                        HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="&#x1F510;"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>
                        <TextBlock Text="SAVE YOUR RECOVERY PHRASE!"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="This is the ONLY way to recover your vault if you forget your password. Store it somewhere safe — it will NOT be shown again."
                                   FontSize="12"
                                   Foreground="{StaticResource WarningBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <!-- Phrase Box -->
                        <Border Background="{StaticResource BackgroundBrush}"
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,0,0,12">
                            <TextBlock Text="{Binding GeneratedRecoveryPhrase}"
                                       FontSize="15"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource AccentBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       LineHeight="28"/>
                        </Border>

                        <!-- Copy Button -->
                        <Button Content="{Binding CopyPhraseButtonText}"
                                Command="{Binding CopyRecoveryPhraseCommand}"
                                FontSize="13"
                                Margin="0,0,0,15"
                                Padding="20,8"
                                HorizontalAlignment="Center"
                                Background="{StaticResource PrimaryBrush}"/>

                        <Button Content="I Have Saved It — Continue"
                                Command="{Binding ContinueAfterRecoveryCommand}"
                                FontSize="14"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- OVERLAY: Post-Recovery Change Password Panel                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{StaticResource BackgroundBrush}"
                Visibility="{Binding IsPostRecoveryChangePassword, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="90">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="16"
                        Padding="40,35"
                        Width="440"
                        HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="&#x1F511;"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="SET NEW MASTER PASSWORD"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Recovery verified. Choose a new master password. A new recovery phrase will also be generated."
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,25"/>

                        <TextBlock Text="New Password"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="NewPasswordBox"
                                     FontSize="14"
                                     Margin="0,0,0,15"
                                     PasswordChanged="NewPasswordBox_PasswordChanged"/>

                        <TextBlock Text="Confirm New Password"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="ConfirmNewPasswordBox"
                                     FontSize="14"
                                     Margin="0,0,0,8"
                                     PasswordChanged="ConfirmNewPasswordBox_PasswordChanged"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11"
                                   Foreground="{StaticResource WarningBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <Button Content="Set New Password &amp; Generate Phrase"
                                Command="{Binding SetNewPasswordAfterRecoveryCommand}"
                                FontSize="14"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- OVERLAY: Lockout Panel                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{StaticResource BackgroundBrush}"
                Visibility="{Binding IsLockedOut, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="80">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="16"
                        Padding="40,35"
                        Width="420"
                        HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="&#x26D4;"
                                   FontSize="56"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>
                        <TextBlock Text="VAULT LOCKED"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="Too many failed password attempts."
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>
                        <Border Background="{StaticResource BackgroundBrush}"
                                CornerRadius="8"
                                Padding="20,14"
                                Margin="0,0,0,8">
                            <TextBlock Text="{Binding LockoutMessage}"
                                       FontSize="15"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource WarningBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Text="The app will automatically unlock when the countdown expires."
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"
                                   Opacity="0.7"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN Login Panel                                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="16"
                Padding="50,40"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="&#x1F510;"
                           FontSize="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="HEAVENLY LOCK"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Secure Password Manager"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>

                <!-- Normal Login Mode -->
                <StackPanel Visibility="{Binding IsRecoveryMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="Master Password"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,5"/>

                    <PasswordBox x:Name="PasswordBox"
                                 FontSize="14"
                                 Margin="0,0,0,20"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <Button Content="Unlock"
                            Command="{Binding UnlockCommand}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,10"
                            Visibility="{Binding IsCreatingVault, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <Button Content="Create Vault"
                            Command="{Binding CreateVaultCommand}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,10"
                            Visibility="{Binding IsCreatingVault, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <TextBlock Text="Forgot password? Use recovery phrase"
                               FontSize="11"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonDown="RecoveryLink_Click"
                               Visibility="{Binding IsCreatingVault, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Recovery Mode -->
                <StackPanel Visibility="{Binding IsRecoveryMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Recovery Phrase (12 words)"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,5"/>

                    <TextBox Text="{Binding RecoveryPhrase, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             Margin="0,0,0,20"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="80"
                             VerticalScrollBarVisibility="Auto"/>

                    <Button Content="Recover Vault"
                            Command="{Binding RecoveryLoginCommand}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,0,10"/>

                    <TextBlock Text="Back to password login"
                               FontSize="11"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonDown="BackLink_Click"/>
                </StackPanel>

                <TextBlock Text="3-Layer Encryption: Argon2id + AES-256-GCM + HKDF"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Opacity="0.6"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
