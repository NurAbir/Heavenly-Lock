<UserControl x:Class="HeavenlyLock.Views.EntryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Entry Details"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"/>
            <!-- Delete Entry Button (top-right, visible when an entry is loaded) -->
            <Button Grid.Column="1"
                    Content="🗑 Delete Entry"
                    Command="{Binding DeleteCommand}"
                    Background="{StaticResource DangerBrush}"
                    Foreground="White"
                    FontSize="12"
                    Padding="12,6"
                    Visibility="{Binding DeleteCommand, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}"/>
        </Grid>

        <!-- Service -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Service"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Service, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext, Converter={StaticResource NullToBoolConverter}}"/>
        </Grid>

        <!-- Username -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Username"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Password -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Password"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas"/>
            <Button Grid.Column="2"
                    Content="Copy"
                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.CopyPasswordCommand}"
                    Margin="10,0,0,0"
                    Padding="15,5"/>
        </Grid>

        <!-- URL -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="URL"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Tags -->
        <Grid Grid.Row="5" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Tags"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding TagsString, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Comma-separated tags"/>
        </Grid>

        <!-- Notes -->
        <Grid Grid.Row="6" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Notes"
                       VerticalAlignment="Top"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,5,0,0"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="100"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- Modified At -->
        <Grid Grid.Row="7" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Modified"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding ModifiedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm} UTC'}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Opacity="0.7"/>
        </Grid>

        <!-- Encryption note -->
        <TextBlock Grid.Row="8"
                   Text="🔒 Password stored with AES-256-GCM encryption"
                   FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   VerticalAlignment="Bottom"
                   Opacity="0.5"/>
    </Grid>
</UserControl>
