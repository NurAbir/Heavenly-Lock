<UserControl x:Class="HeavenlyLock.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:HeavenlyLock.Views"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource SurfaceBrush}" 
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="32" Height="32" Margin="0,0,10,0"/>
                    <TextBlock Text="HEAVENLY LOCK" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBox Grid.Column="1" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="300"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         ToolTip="Search entries..."/>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal">
                    <Button Content="Change Password" 
                            Command="{Binding ToggleChangePasswordCommand}"
                            Background="{StaticResource WarningBrush}"
                            Margin="0,0,10,0"
                            Padding="12,8"/>
                    <Button Content="Delete Vault" 
                            Command="{Binding DeleteVaultCommand}"
                            Background="{StaticResource DangerBrush}"
                            Margin="0,0,10,0"
                            Padding="12,8"/>
                    <Button Content="Lock" 
                            Command="{Binding LockCommand}"
                            Background="#555"
                            Margin="0,0,10,0"
                            Padding="12,8"/>
                    <Button Content="Save" 
                            Command="{Binding SaveCommand}"
                            Padding="12,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Change Password Panel -->
        <Border Grid.Row="1" 
                Background="{StaticResource SurfaceBrush}" 
                CornerRadius="12"
                Padding="30"
                Margin="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="400"
                Visibility="{Binding ShowChangePassword, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="50">
            <StackPanel>
                <TextBlock Text="Change Master Password" 
                           FontSize="18" 
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Current Password" 
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding CurrentPassword, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,15"/>

                <TextBlock Text="New Password" 
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Confirm New Password" 
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Cancel"
                            Command="{Binding ToggleChangePasswordCommand}"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1"
                            Margin="0,0,10,0"/>
                    <Button Content="Change Password"
                            Command="{Binding ChangePasswordCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20" Visibility="{Binding ShowChangePassword, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Entry List -->
            <Border Grid.Column="0" 
                    Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12"
                    Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="{StaticResource PrimaryBrush}" 
                            CornerRadius="12,12,0,0"
                            Padding="15,12">
                        <Grid>
                            <TextBlock Text="Password Vault" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <Button Content="+" 
                                    Command="{Binding AddEntryCommand}"
                                    HorizontalAlignment="Right"
                                    Padding="12,4"
                                    FontSize="16"
                                    FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding Entries}"
                              SelectedItem="{Binding SelectedEntry}"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="5">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" 
                                        CornerRadius="6"
                                        Background="Transparent">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Service}" 
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Username}" 
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding TagsDisplay}" 
                                                   FontSize="10"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,2,0,0"
                                                   Opacity="0.7"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Entry Details / Generator -->
            <TabControl Grid.Column="1" 
                        Background="Transparent">
                <TabItem Header="Entry Details">
                    <views:EntryEditorView DataContext="{Binding SelectedEntry}"/>
                </TabItem>
                <TabItem Header="Password Generator">
                    <views:GeneratorView/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource SurfaceBrush}" 
                Padding="20,8">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>