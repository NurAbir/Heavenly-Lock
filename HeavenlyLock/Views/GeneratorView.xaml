<UserControl x:Class="HeavenlyLock.Views.GeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Password Generator" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,20"/>

        <!-- Mode Toggle -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,20">
            <RadioButton Content="Random" 
                         IsChecked="{Binding IsPassphraseMode, Converter={StaticResource InverseBoolConverter}}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Margin="0,0,20,0"/>
            <RadioButton Content="Passphrase" 
                         IsChecked="{Binding IsPassphraseMode}"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Random Mode Controls -->
        <StackPanel Grid.Row="2" 
                    Visibility="{Binding IsPassphraseMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="Length" 
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <Slider Grid.Column="1" 
                        Minimum="4" 
                        Maximum="128" 
                        Value="{Binding Length}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"/>
                <TextBlock Grid.Column="2" 
                           Text="{Binding Length}" 
                           Width="30"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>

            <UniformGrid Columns="2" Margin="0,0,0,15">
                <CheckBox Content="Uppercase (A-Z)" 
                          IsChecked="{Binding UseUppercase}"/>
                <CheckBox Content="Lowercase (a-z)" 
                          IsChecked="{Binding UseLowercase}"/>
                <CheckBox Content="Digits (0-9)" 
                          IsChecked="{Binding UseDigits}"/>
                <CheckBox Content="Symbols (!@#...)" 
                          IsChecked="{Binding UseSymbols}"/>
                <CheckBox Content="Exclude Ambiguous (0O1lI)" 
                          IsChecked="{Binding ExcludeAmbiguous}"
                          Grid.ColumnSpan="2"/>
            </UniformGrid>
        </StackPanel>

        <!-- Passphrase Mode Controls -->
        <StackPanel Grid.Row="2" 
                    Visibility="{Binding IsPassphraseMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="Word Count" 
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <Slider Grid.Column="1" 
                        Minimum="3" 
                        Maximum="12" 
                        Value="{Binding WordCount}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"/>
                <TextBlock Grid.Column="2" 
                           Text="{Binding WordCount}" 
                           Width="30"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>
        </StackPanel>

        <!-- Generated Password Display -->
        <Border Grid.Row="3" 
                Background="{StaticResource BackgroundBrush}" 
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="{Binding GeneratedPassword}" 
                           FontSize="16"
                           FontFamily="Consolas"
                           Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Entropy Display -->
        <Grid Grid.Row="4" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" 
                       Text="Entropy: " 
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Grid.Column="1" 
                       Text="{Binding Entropy, StringFormat='{}{0:F1} bits'}" 
                       Foreground="{StaticResource AccentBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,15,0"/>
            <TextBlock Grid.Column="2" 
                       Text="{Binding StrengthText}" 
                       Foreground="{Binding StrengthText, Converter={StaticResource StrengthToColorConverter}}"
                       FontWeight="Bold"/>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal">
            <Button Content="Generate New" 
                    Command="{Binding GenerateCommand}"
                    Margin="0,0,10,0"/>
            <Button Content="Copy to Clipboard" 
                    Command="{Binding CopyCommand}"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"/>
        </StackPanel>

        <TextBlock Grid.Row="6" 
                   Text="Clipboard auto-clears after 30 seconds for security." 
                   FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,15,0,0"
                   Opacity="0.6"/>
    </Grid>
</UserControl>